<Window x:Class="ScreenshotOCR.Windows.RegionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="Black"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        Focusable="True">
    <Grid>
        <Image x:Name="FrozenImage" Stretch="Fill"
               SnapsToDevicePixels="True"
               RenderOptions.BitmapScalingMode="NearestNeighbor"/>

        <!-- Dim overlay with a cut-out hole for the selection -->
        <Path x:Name="DimPath" Fill="#80000000">
            <Path.Data>
                <CombinedGeometry x:Name="DimGeometry" GeometryCombineMode="Exclude">
                    <CombinedGeometry.Geometry1>
                        <RectangleGeometry x:Name="OuterRect"/>
                    </CombinedGeometry.Geometry1>
                    <CombinedGeometry.Geometry2>
                        <RectangleGeometry x:Name="SelectionHole"/>
                    </CombinedGeometry.Geometry2>
                </CombinedGeometry>
            </Path.Data>
        </Path>

        <!-- Selection rectangle border -->
        <Rectangle x:Name="SelectionBorder"
                   Stroke="#FFFFFFFF"
                   StrokeThickness="1"
                   Visibility="Collapsed"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   SnapsToDevicePixels="True"/>

        <!-- Hint label -->
        <Border x:Name="HintBox"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,40,0,0"
                Background="#CC202020"
                CornerRadius="8"
                Padding="14,8">
            <TextBlock Text="Click and drag to select an area  ·  Esc to cancel"
                       Foreground="#FFFFFFFF"
                       FontSize="13"
                       FontFamily="Segoe UI"/>
        </Border>

        <!-- Size readout near the cursor -->
        <Border x:Name="SizeBox"
                Visibility="Collapsed"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="#CC202020"
                CornerRadius="4"
                Padding="6,3">
            <TextBlock x:Name="SizeText"
                       Foreground="#FFFFFFFF"
                       FontSize="11"
                       FontFamily="Segoe UI"/>
        </Border>
    </Grid>
</Window>
